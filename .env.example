# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Meta / Instagram Integration
META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-verify-token
META_GRAPH_API_VERSION=v18.0

# Google OAuth (Calendar, Gmail, Drive, Business Profile)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_PROJECT_ID=your-google-project-id

# OpenAI (para embeddings y chatbot)
OPENAI_API_KEY=your-openai-api-key

# Encryption (para tokens OAuth)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Edge Functions URL (for webhooks)
SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
